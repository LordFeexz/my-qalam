---
import BookmarkButton from "$libs/components/common/BookmarkButton.svelte";

interface Props {
  name: string;
  slug: string;
  totalHadith: number | null;
  description: string | null;
  href: string;
}

const { name, slug, totalHadith, description, href } = Astro.props;
---

<a
  data-astro-prefetch
  href={href}
  class="flex flex-col gap-3 p-5 rounded-xl border border-border/40 bg-card hover:bg-accent hover:border-border transition-colors h-full"
>
  <div class="flex items-start justify-between gap-4">
    <div class="flex items-center gap-2">
      <h3 class="font-semibold text-lg">{name}</h3>
      <div
        onclick="event.preventDefault();"
        onkeydown="event.stopPropagation();"
        role="presentation"
      >
        <BookmarkButton
          client:load
          item={{
            id: `hadithBook-${slug}`,
            type: "hadithBook",
            slug,
            name,
            totalHadith,
            savedAt: 0,
          }}
        />
      </div>
    </div>
    {
      totalHadith && (
        <span class="shrink-0 text-xs font-medium px-2.5 py-1 rounded-full bg-primary/10 text-primary">
          {totalHadith} Hadis
        </span>
      )
    }
  </div>

  {
    description && (
      <p class="text-sm text-muted-foreground line-clamp-3 leading-relaxed mt-auto">
        {description}
      </p>
    )
  }
</a>
