---
import "../../../styles/global.css";
import { ClientRouter } from "astro:transitions";
import type { PageProps } from "$libs/interfaces/global";
import Navbar from "./Navbar.svelte";
import Footer from "./Footer.astro";

interface Props extends PageProps {}

const {
  title,
  robots,
  keywords = [],
  opengraph,
  twitter,
  description,
  schemas = [],
} = Astro.props;
const baseUrl = import.meta.env.PUBLIC_DOMAIN;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "My Qalam",
  url: baseUrl,
  logo: `${baseUrl}/logo.png`,
  sameAs: [],
  foundingDate: "2026",
  areaServed: "Indonesia",
};
---

<script is:inline>
  const isBrowser = typeof localStorage !== "undefined";
  const getThemePreference = () => {
    if (isBrowser && localStorage.getItem("theme")) {
      return localStorage.getItem("theme");
    }
    return window.matchMedia("(prefers-color-scheme: dark)").matches
      ? "dark"
      : "light";
  };
  const isDark = getThemePreference() === "dark";
  document.documentElement.classList[isDark ? "add" : "remove"]("dark");

  if (isBrowser) {
    const observer = new MutationObserver(() => {
      const isDark = document.documentElement.classList.contains("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });
  }
</script>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="apple-mobile-web-app-title" content="My Qalam" />
    <link rel="icon" href="/icons/192x192.png" />
    <link rel="apple-touch-icon" href="/icons/512x512.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#343434" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {opengraph?.title && <meta property="og:title" content={opengraph.title} />}
    {
      opengraph?.description && (
        <meta property="og:description" content={opengraph.description} />
      )
    }
    {opengraph?.image && <meta property="og:image" content={opengraph.image} />}
    <meta
      property="og:url"
      content={`${import.meta.env.PUBLIC_DOMAIN}${Astro.url.pathname}`}
    />
    {opengraph?.type && <meta property="og:type" content={opengraph.type} />}
    {
      opengraph?.tags && (
        <meta property="og:tags" content={opengraph.tags.join(", ")} />
      )
    }
    <meta property="og:locale" content="id-ID" />
    <meta property="og:site_name" content="My Qalam" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {twitter?.card && <meta name="twitter:card" content={twitter.card} />}
    {twitter?.title && <meta name="twitter:title" content={twitter.title} />}
    {
      twitter?.description && (
        <meta name="twitter:description" content={twitter.description} />
      )
    }
    {twitter?.image && <meta name="twitter:image" content={twitter.image} />}
    <meta name="twitter:site" content="My Qalam" />
    <link
      rel="canonical"
      href={`${import.meta.env.PUBLIC_DOMAIN}${Astro.url.pathname}`}
    />
    {
      robots && (
        <meta
          name="robots"
          content={`${robots.index ? "index" : "noindex"}, ${robots.follow ? "follow" : "nofollow"}`}
        />
      )
    }
    {
      robots?.googleBot && (
        <meta
          name="googlebot"
          content={`${robots.googleBot.index ? "index" : "noindex"}, ${robots.googleBot.follow ? "follow" : "nofollow"}`}
        />
      )
    }
    {
      keywords.length > 0 && (
        <meta name="keywords" content={keywords.join(", ")} />
      )
    }
    <meta name="publisher" content="My Qalam" />
    <ClientRouter />
    {
      schemas.map((schema) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(schema, null, 4)}
        />
      ))
    }
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(organizationSchema, null, 4)}
    />
  </head>
  <body class="flex min-h-dvh flex-col">
    <Navbar client:load />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
