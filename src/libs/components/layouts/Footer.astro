---
interface FooterLink {
  label: string;
  href: string;
}

interface FooterSection {
  title: string;
  links: FooterLink[];
}

const sections: FooterSection[] = [
  {
    title: "Explore",
    links: [
      { label: "Quran", href: "/quran" },
      { label: "Hadith", href: "/hadith" },
      { label: "Sirah", href: "/sirah" },
    ],
  },
  {
    title: "Tools",
    links: [
      { label: "Cari", href: "/search" },
      { label: "Asisten AI", href: "/ai" },
      { label: "Bookmarks", href: "/bookmarks" },
    ],
  },
  {
    title: "Tentang",
    links: [
      { label: "Tentang Kami", href: "/about" },
      { label: "Kebijakan Privasi", href: "/privacy" },
      { label: "Ketentuan Penggunaan", href: "/terms" },
    ],
  },
];

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border/40 bg-muted/30">
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <!-- Main footer content -->
    <div class="grid grid-cols-2 gap-8 py-10 sm:grid-cols-3 md:grid-cols-4">
      <!-- Brand -->
      <div class="col-span-2 sm:col-span-3 md:col-span-1">
        <a
          href="/"
          class="inline-block text-lg font-semibold tracking-tight transition-opacity hover:opacity-80"
          aria-label="My Qalam home"
        >
          My Qalam
        </a>
        <p class="mt-2 max-w-xs text-sm leading-relaxed text-muted-foreground">
          Platform pembelajaran Al-Quran, Hadith, dan Sirah yang modern dan
          mudah diakses.
        </p>
      </div>

      <!-- Link sections -->
      {
        sections.map((section) => (
          <div>
            <h3 class="text-sm font-semibold text-foreground">
              {section.title}
            </h3>
            <ul class="mt-3 flex flex-col gap-2" role="list">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:rounded"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <hr class="h-px w-full shrink-0 border-0 bg-border" />

    <!-- Bottom bar -->
    <div
      class="flex flex-col items-center justify-between gap-3 py-6 text-sm text-muted-foreground sm:flex-row"
    >
      <p>&copy; {currentYear} My Qalam. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="/privacy" class="transition-colors hover:text-foreground">
          Kebijakan Privasi
        </a>
        <a href="/terms" class="transition-colors hover:text-foreground">
          Ketentuan Penggunaan
        </a>
      </div>
    </div>
  </div>
</footer>
