---
interface Props {
  title: string;
  slug: string;
  description: string | null;
  yearLabel: string | null;
  href: string;
}

const { title, slug, description, yearLabel, href } = Astro.props;
---

<div class="relative pl-8 pb-8 group last:pb-0">
  <div
    class="absolute left-0 top-1 bottom-[-8px] w-px bg-border group-last:hidden"
  >
  </div>
  <div
    class="absolute left-[-4px] top-1.5 w-2 h-2 rounded-full bg-primary/40 ring-4 ring-background"
  >
  </div>

  <a
    data-astro-prefetch
    href={href}
    class="block rounded-xl border border-border/40 bg-card p-5 hover:bg-accent hover:border-border transition-colors"
  >
    {
      yearLabel && (
        <div class="text-xs font-medium text-primary mb-2">{yearLabel}</div>
      )
    }
    <h3
      class="font-semibold text-lg mb-2 group-hover:text-primary transition-colors"
    >
      {title}
    </h3>
    {
      description && (
        <p class="text-sm text-muted-foreground leading-relaxed line-clamp-2">
          {description}
        </p>
      )
    }
  </a>
</div>
