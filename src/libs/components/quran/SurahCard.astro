---
interface Props {
  number: number;
  nameArabic: string;
  nameLatin: string;
  totalAyah: number;
  revelationPlace?: string | null;
  href: string;
}

const { number, nameArabic, nameLatin, totalAyah, revelationPlace, href } =
  Astro.props;
---

<a
  data-astro-prefetch
  href={href}
  class="group flex items-center justify-between p-4 rounded-xl border border-border/40 bg-card hover:bg-accent hover:border-border transition-colors"
>
  <div class="flex items-center gap-4">
    <div class="relative flex items-center justify-center w-10 h-10">
      <div
        class="absolute inset-0 bg-muted rounded-full transform rotate-45 group-hover:bg-background transition-colors"
      >
      </div>
      <span class="relative z-10 text-xs font-semibold">{number}</span>
    </div>

    <div class="flex flex-col gap-1">
      <h3 class="font-semibold">{nameLatin}</h3>
      <div class="flex items-center gap-2 text-xs text-muted-foreground">
        <span class="capitalize">{revelationPlace}</span>
        <span>•</span>
        <span>{totalAyah} Ayat</span>
      </div>
    </div>
  </div>

  <div
    class="text-xl font-arabic text-primary"
    style="font-family: 'KFGQPC Uthman Taha Naskh', serif;"
    dir="rtl"
  >
    {nameArabic}
  </div>
</a>
