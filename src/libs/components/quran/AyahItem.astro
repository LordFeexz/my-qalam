---
import BookmarkButton from "$libs/components/common/BookmarkButton.svelte";

interface Props {
  ayahNumber: number;
  arabicText: string;
  translationId: string;
  tafsirContent?: string | null;
  surahNumber: number;
  surahName: string;
}

const { ayahNumber, arabicText, translationId, tafsirContent, surahNumber, surahName } = Astro.props;
---

<div class="py-6 border-b border-border/40 last:border-0" id={`ayah-${ayahNumber}`}>
  <div class="flex flex-col gap-6">
    <div class="flex items-start justify-between gap-4 w-full">
      <div class="flex flex-col items-center gap-2">
        <div class="shrink-0 flex items-center justify-center w-8 h-8 rounded-full bg-muted text-xs font-medium">
          {ayahNumber}
        </div>
        <BookmarkButton 
          client:load 
          item={{
            id: `ayah-${surahNumber}-${ayahNumber}`,
            type: 'ayah',
            surahNumber,
            surahName,
            ayahNumber,
            translationSnippet: translationId.slice(0, 120) + (translationId.length > 120 ? '...' : ''),
            savedAt: 0
          }} 
        />
      </div>
      
      <div 
        class="text-right text-3xl leading-[2.5] text-foreground font-arabic w-full"
        style="font-family: 'KFGQPC Uthman Taha Naskh', 'Amiri', serif;" 
        dir="rtl"
      >
        {arabicText}
      </div>
    </div>
    
    <div class="pl-12 text-muted-foreground leading-relaxed">
      {translationId}
    </div>
    
    {tafsirContent && (
      <div class="pl-12 mt-2">
        <details class="group border border-border/60 rounded-lg bg-card/50">
          <summary class="cursor-pointer px-4 py-3 text-sm font-medium hover:bg-accent/50 transition-colors list-none flex justify-between items-center">
            <span>Lihat Tafsir Kemenag</span>
            <svg class="w-4 h-4 transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="px-4 pb-4 pt-2 text-sm text-muted-foreground border-t border-border/40 prose prose-sm dark:prose-invert max-w-none">
            {tafsirContent}
          </div>
        </details>
      </div>
    )}
  </div>
</div>

<style>
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
