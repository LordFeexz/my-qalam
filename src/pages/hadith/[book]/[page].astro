---
export const prerender = true;
import Root from "$libs/components/layouts/Root.astro";
import HadithItem from "$libs/components/hadith/HadithItem.astro";
import { getAllHadithBooks, getHadithsByBookPaginated, getTotalHadithPages } from "$libs/db/queries/hadith.queries";
import type { PageProps } from "$libs/interfaces/global";
import type { BreadcrumbList, ItemList, WebPage } from "schema-dts";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const books = await getAllHadithBooks();
  
  // To avoid fetching all hadiths into memory at once for pagination,
  // we will construct the paths manually for each page.
  // Astro's native `paginate` usually requires passing the full array,
  // but since we query per page, we will return an array of paths directly.
  
  const LIMIT = 100;
  const paths = [];

  for (const book of books) {
    const totalPages = await getTotalHadithPages(book.id, LIMIT);
    for (let page = 1; page <= totalPages; page++) {
      paths.push({
        params: { book: book.slug, page: page.toString() },
        props: { book, page, totalPages, limit: LIMIT }
      });
    }
  }
  
  return paths;
}

const { book, page, totalPages, limit } = Astro.props;
const hadiths = await getHadithsByBookPaginated(book.id, page, limit);

const baseUrl = import.meta.env.PUBLIC_DOMAIN;
const description = `Baca hadis dari kitab ${book.name} halaman ${page} dari ${totalPages}.`;

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: `${book.name} (Halaman ${page}) - My Qalam`,
    description,
  } as WebPage,
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Beranda", item: baseUrl },
      { "@type": "ListItem", position: 2, name: "Kitab Hadis", item: `${baseUrl}/hadith` },
      { "@type": "ListItem", position: 3, name: book.name, item: `${baseUrl}/hadith/${book.slug}/1` }
    ]
  } as BreadcrumbList,
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: hadiths.map((h, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: `Hadis No. ${h.number}`,
      url: `${baseUrl}/hadith/${book.slug}/hadith/${h.number}`
    }))
  } as ItemList
];

const pageProps: PageProps = {
  title: `${book.name} (Halaman ${page}) - My Qalam`,
  description,
  keywords: ["Hadis", book.name, "halaman", page.toString(), book.slug, "kumpulan hadis"],
  robots: { index: true, follow: true },
  opengraph: {
    title: `${book.name} (Halaman ${page}) - My Qalam`,
    description,
    image: `${baseUrl}/logo.png`,
    type: "website",
  },
  twitter: {
    card: "summary_large_image",
    title: `${book.name} (Halaman ${page}) - My Qalam`,
    description,
    image: `${baseUrl}/logo.png`,
  },
  schemas
};
---

<Root {...pageProps}>
  <div class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
    <div class="mb-8 border-b border-border/40 pb-6">
      <div class="flex items-center gap-2 text-sm text-muted-foreground mb-4">
        <a href="/hadith" class="hover:text-primary transition-colors">Kitab Hadis</a>
        <span>/</span>
        <span class="text-foreground">{book.name}</span>
      </div>
      
      <div class="flex items-end justify-between">
        <div>
          <h1 class="text-3xl font-bold tracking-tight mb-2">{book.name}</h1>
          <p class="text-muted-foreground">Total {book.totalHadith} hadis</p>
        </div>
      </div>
    </div>
    
    <div class="flex flex-col">
      {hadiths.map((h) => (
        <HadithItem 
          number={h.number}
          arabicText={h.arabicText}
          translationId={h.translationId}
          grade={h.grade}
          href={`/hadith/${book.slug}/hadith/${h.number}`}
        />
      ))}
    </div>
    
    <!-- Pagination -->
    <div class="mt-8 flex items-center justify-center gap-2">
      {page > 1 && (
        <a href={`/hadith/${book.slug}/${page - 1}`} class="px-4 py-2 border border-border/60 rounded-lg hover:bg-accent transition-colors text-sm font-medium">
          Sebelumnya
        </a>
      )}
      
      <span class="px-4 py-2 text-sm text-muted-foreground">
        Halaman {page} dari {totalPages}
      </span>
      
      {page < totalPages && (
        <a href={`/hadith/${book.slug}/${page + 1}`} class="px-4 py-2 border border-border/60 rounded-lg hover:bg-accent transition-colors text-sm font-medium">
          Selanjutnya
        </a>
      )}
    </div>
  </div>
</Root>
