---
export const prerender = true;

import Root from "$libs/components/layouts/Root.astro";
import HadithBookCard from "$libs/components/hadith/HadithBookCard.astro";
import { getAllHadithBooks } from "$libs/db/queries/hadith.queries";
import type { PageProps } from "$libs/interfaces/global";
import type { BreadcrumbList, ItemList, WebPage } from "schema-dts";

const books = await getAllHadithBooks();
const baseUrl = import.meta.env.PUBLIC_DOMAIN;

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Kitab Hadis - My Qalam",
    description: "Jelajahi berbagai kitab hadis shahih dan terpercaya.",
  } as WebPage,
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Beranda", item: baseUrl },
      { "@type": "ListItem", position: 2, name: "Kitab Hadis", item: `${baseUrl}/hadith` }
    ]
  } as BreadcrumbList,
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: books.map((book, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: book.name,
      url: `${baseUrl}/hadith/${book.slug}/1`
    }))
  } as ItemList
];

const pageProps: PageProps = {
  title: "Kumpulan Hadis - My Qalam",
  description: "Jelajahi berbagai kitab hadis terpercaya seperti Shahih Bukhari, Muslim, Tirmidzi, dan lainnya.",
  keywords: ["Hadis", "hadith", "sunnah", "shahih bukhari", "shahih muslim", "kitab hadis"],
  robots: { index: true, follow: true },
  opengraph: {
    title: "Kumpulan Hadis - My Qalam",
    description: "Jelajahi berbagai kitab hadis shahih dan terpercaya.",
    image: `${baseUrl}/logo.png`,
    type: "website",
  },
  twitter: {
    card: "summary_large_image",
    title: "Kumpulan Hadis - My Qalam",
    description: "Jelajahi berbagai kitab hadis shahih dan terpercaya.",
    image: `${baseUrl}/logo.png`,
  },
  schemas
};
---

<Root {...pageProps}>
  <div class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
    <div class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight mb-2">Kitab Hadis</h1>
      <p class="text-muted-foreground">Kumpulan hadis dari berbagai kitab yang shahih dan terpercaya.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {books.map((book) => (
        <HadithBookCard 
          name={book.name}
          slug={book.slug}
          totalHadith={book.totalHadith}
          description={book.description}
          href={`/hadith/${book.slug}/1`}
        />
      ))}
    </div>
  </div>
</Root>
