---
export const prerender = true;
import BookmarkButton from "$libs/components/common/BookmarkButton.svelte";
import Root from "$libs/components/layouts/Root.astro";
import {
  getAllSirahChapters,
  getSirahBySlug,
} from "$libs/db/queries/sirah.queries";
import { marked } from "marked";
import type { PageProps } from "$libs/interfaces/global";
import type { Article, BreadcrumbList, WebPage, WithContext } from "schema-dts";

export async function getStaticPaths() {
  const chapters = await getAllSirahChapters();
  return chapters.map((c, index) => ({
    params: { slug: c.slug },
    props: {
      prevSlug: index > 0 ? chapters[index - 1].slug : null,
      nextSlug: index < chapters.length - 1 ? chapters[index + 1].slug : null,
    },
  }));
}

const { prevSlug, nextSlug } = Astro.props;
const { slug } = Astro.params;
const chapter = await getSirahBySlug(slug as string);

if (!chapter) {
  return Astro.redirect("/404");
}

const baseUrl = import.meta.env.PUBLIC_DOMAIN;
const description =
  chapter.description ||
  `Membaca bagian ${chapter.title} dari Sirah Nabawiyah.`;

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: `${chapter.title} - My Qalam`,
    description,
  } as WithContext<WebPage>,
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Beranda", item: baseUrl },
      {
        "@type": "ListItem",
        position: 2,
        name: "Sirah Nabawiyah",
        item: `${baseUrl}/sirah`,
      },
      {
        "@type": "ListItem",
        position: 3,
        name: chapter.title,
        item: `${baseUrl}/sirah/${chapter.slug}`,
      },
    ],
  } as WithContext<BreadcrumbList>,
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: chapter.title,
    description,
    url: `${baseUrl}/sirah/${chapter.slug}`,
    datePublished: chapter.createdAt?.toISOString(),
    dateModified: chapter.updatedAt?.toISOString(),
    author: {
      "@type": "Person",
      name: "My Qalam",
    },
    articleBody: chapter.content,
    articleSection: "Sirah Nabawiyah",
  } as WithContext<Article>,
];

const pageProps: PageProps = {
  title: `${chapter.title} - My Qalam`,
  description,
  keywords: [
    "Sirah Nabawiyah",
    chapter.title,
    chapter.yearLabel || "",
    "Nabi Muhammad",
    "sejarah",
  ].filter(Boolean),
  robots: { index: true, follow: true },
  opengraph: {
    title: `${chapter.title} - My Qalam`,
    description,
    image: `${baseUrl}/logo.png`,
    type: "article",
  },
  twitter: {
    card: "summary_large_image",
    title: `${chapter.title} - My Qalam`,
    description,
    image: `${baseUrl}/logo.png`,
  },
  schemas,
};
---

<Root {...pageProps}>
  <article class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
    <div class="mb-8 border-b border-border/40 pb-8 text-center">
      <a
        href="/sirah"
        class="text-sm font-medium text-primary hover:underline mb-4 inline-block"
      >
        &larr; Kembali ke Daftar Sirah
      </a>

      {
        chapter.yearLabel && (
          <div class="text-sm font-medium text-muted-foreground mb-3">
            {chapter.yearLabel}
          </div>
        )
      }

      <div class="flex items-center justify-center gap-3 mb-4">
        <h1
          class="text-3xl md:text-4xl font-bold tracking-tight leading-tight m-0"
        >
          {chapter.title}
        </h1>
        <BookmarkButton
          client:load
          item={{
            id: `sirah-${slug}`,
            type: "sirah",
            slug: slug,
            title: chapter.title,
            yearLabel: chapter.yearLabel,
            savedAt: 0,
          }}
        />
      </div>

      {
        chapter.description && (
          <p class="text-lg text-muted-foreground max-w-2xl mx-auto leading-relaxed">
            {chapter.description}
          </p>
        )
      }
    </div>

    <div
      class="prose prose-neutral dark:prose-invert prose-lg max-w-none prose-headings:font-semibold prose-a:text-primary"
    >
      <div set:html={marked.parse(chapter.content)} />
    </div>

    <div
      class="mt-16 flex justify-between items-center border-t border-border/40 pt-8"
    >
      {
        prevSlug ? (
          <a
            href={`/sirah/${prevSlug}`}
            class="text-sm font-medium hover:text-primary transition-colors"
          >
            &larr; Bab Sebelumnya
          </a>
        ) : (
          <div />
        )
      }

      {
        nextSlug ? (
          <a
            href={`/sirah/${nextSlug}`}
            class="text-sm font-medium hover:text-primary transition-colors"
          >
            Bab Selanjutnya &rarr;
          </a>
        ) : (
          <div />
        )
      }
    </div>
  </article>
</Root>
