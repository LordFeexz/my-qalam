---
export const prerender = true;
import Root from "$libs/components/layouts/Root.astro";
import SearchPage from "$libs/components/search/SearchPage.svelte";
import type { PageProps } from "$libs/interfaces/global";
import type {
  BreadcrumbList,
  WebPage,
  WebSite,
  SearchAction,
  WithContext,
} from "schema-dts";

const baseUrl = import.meta.env.PUBLIC_DOMAIN;

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Pencarian - My Qalam",
    description:
      "Cari ayat Al-Quran, hadis, dan sirah Nabi Muhammad SAW. Pencarian mendukung teks Arab, Indonesia, dan transliterasi.",
  } as WithContext<WebPage>,
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Beranda", item: baseUrl },
      {
        "@type": "ListItem",
        position: 2,
        name: "Pencarian",
        item: `${baseUrl}/search`,
      },
    ],
  } as WithContext<BreadcrumbList>,
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    url: baseUrl,
    potentialAction: {
      "@type": "SearchAction",
      target: {
        "@type": "EntryPoint",
        urlTemplate: `${baseUrl}/search?q={search_term_string}`,
      },
      "query-input": "required name=search_term_string",
    } as SearchAction,
  } as WithContext<WebSite>,
];

const pageProps: PageProps = {
  title: "Pencarian - My Qalam",
  description:
    "Cari ayat Al-Quran, hadis, dan sirah Nabi Muhammad SAW. Pencarian mendukung teks Arab, Indonesia, dan transliterasi.",
  keywords: [
    "cari quran",
    "cari hadis",
    "cari sirah",
    "pencarian islami",
    "search quran",
    "search hadith",
  ],
  robots: { index: true, follow: true },
  opengraph: {
    title: "Pencarian - My Qalam",
    description: "Cari ayat Al-Quran, hadis, dan sirah Nabi Muhammad SAW.",
    image: `${baseUrl}/logo.png`,
    type: "website",
  },
  twitter: {
    card: "summary_large_image",
    title: "Pencarian - My Qalam",
    description: "Cari ayat Al-Quran, hadis, dan sirah Nabi Muhammad SAW.",
    image: `${baseUrl}/logo.png`,
  },
  schemas,
};
---

<Root {...pageProps}>
  <div class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
    <div class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight mb-2">Pencarian</h1>
      <p class="text-muted-foreground">
        Temukan ayat, hadis, atau sirah yang Anda cari.
      </p>
    </div>

    <SearchPage client:only="svelte" />
  </div>
</Root>
