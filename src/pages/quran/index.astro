---
export const prerender = true;

import Root from "$libs/components/layouts/Root.astro";
import SurahCard from "$libs/components/quran/SurahCard.astro";
import { getAllSurahs } from "$libs/db/queries/quran.queries";
import type { PageProps } from "$libs/interfaces/global";
import type { BreadcrumbList, ItemList, WebPage } from "schema-dts";

const surahs = await getAllSurahs();
const baseUrl = import.meta.env.PUBLIC_DOMAIN;

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Al-Quran - My Qalam",
    description: "Jelajahi 114 Surah Al-Quran beserta terjemahan dan tafsir.",
  } as WebPage,
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Beranda", item: baseUrl },
      { "@type": "ListItem", position: 2, name: "Al-Quran", item: `${baseUrl}/quran` }
    ]
  } as BreadcrumbList,
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: surahs.map((surah, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: `Surah ${surah.nameLatin}`,
      url: `${baseUrl}/quran/${surah.number}`
    }))
  } as ItemList
];

const pageProps: PageProps = {
  title: "Al-Quran - My Qalam",
  description: "Baca Al-Quran dengan terjemahan dan tafsir. Tersedia 114 Surah lengkap dengan audio dan asbabun nuzul.",
  keywords: ["Al-Quran", "quran online", "quran indonesia", "tafsir kemenag", "baca quran", "114 surah"],
  robots: { index: true, follow: true },
  opengraph: {
    title: "Al-Quran - My Qalam",
    description: "Jelajahi 114 Surah Al-Quran beserta terjemahan dan tafsir.",
    image: `${baseUrl}/logo.png`,
    type: "website",
  },
  twitter: {
    card: "summary_large_image",
    title: "Al-Quran - My Qalam",
    description: "Jelajahi 114 Surah Al-Quran beserta terjemahan dan tafsir.",
    image: `${baseUrl}/logo.png`,
  },
  schemas
};
---

<Root {...pageProps}>
  <div class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
    <div class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight mb-2">Al-Quran</h1>
      <p class="text-muted-foreground">Jelajahi 114 Surah Al-Quran beserta terjemahan dan tafsir.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {surahs.map((surah) => (
        <SurahCard 
          number={surah.number}
          nameArabic={surah.nameArabic}
          nameLatin={surah.nameLatin}
          totalAyah={surah.totalAyah}
          revelationPlace={surah.revelationPlace}
          href={`/quran/${surah.number}`}
        />
      ))}
    </div>
  </div>
</Root>
