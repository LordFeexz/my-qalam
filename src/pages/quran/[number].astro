---
export const prerender = true;
import Root from "$libs/components/layouts/Root.astro";
import SurahHeader from "$libs/components/quran/SurahHeader.astro";
import AyahItem from "$libs/components/quran/AyahItem.astro";
import { getAllSurahs, getSurahByNumber, getAyahsBySurah, getTafsirsByAyahIds } from "$libs/db/queries/quran.queries";
import type { PageProps } from "$libs/interfaces/global";
import type { BreadcrumbList, FAQPage, WebPage } from "schema-dts";

export async function getStaticPaths() {
  const surahs = await getAllSurahs();
  return surahs.map((s) => ({
    params: { number: s.number.toString() },
  }));
}

const number = parseInt(Astro.params.number as string);
const surah = await getSurahByNumber(number);
const ayahs = await getAyahsBySurah(surah.id);

const ayahIds = ayahs.map((a) => a.id);
const tafsirs = await getTafsirsByAyahIds(ayahIds, "kemenag");

const tafsirMap = new Map();
tafsirs.forEach((t) => {
  tafsirMap.set(t.ayahId, t.content);
});

const baseUrl = import.meta.env.PUBLIC_DOMAIN;
const description = `Baca Surah ${surah.nameLatin} beserta terjemahan bahasa Indonesia dan tafsir Kemenag. Terdiri dari ${surah.totalAyah} ayat.`;

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: `Surah ${surah.nameLatin} - My Qalam`,
    description,
  } as WebPage,
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Beranda", item: baseUrl },
      { "@type": "ListItem", position: 2, name: "Al-Quran", item: `${baseUrl}/quran` },
      { "@type": "ListItem", position: 3, name: `Surah ${surah.nameLatin}`, item: `${baseUrl}/quran/${surah.number}` }
    ]
  } as BreadcrumbList,
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: ayahs.map(a => {
      const tafsir = tafsirMap.get(a.id);
      return {
        "@type": "Question",
        name: `Apa terjemahan Surah ${surah.nameLatin} ayat ${a.ayahNumber}?`,
        acceptedAnswer: {
          "@type": "Answer",
          text: a.translationId + (tafsir ? ` Tafsir: ${tafsir.slice(0, 300)}...` : "")
        }
      };
    })
  } as FAQPage
];

const pageProps: PageProps = {
  title: `Surah ${surah.nameLatin} - My Qalam`,
  description,
  keywords: ["Al-Quran", surah.nameLatin, "tafsir", "terjemahan", "ayat", `surah ke ${surah.number}`],
  robots: { index: true, follow: true },
  opengraph: {
    title: `Surah ${surah.nameLatin} - My Qalam`,
    description,
    image: `${baseUrl}/logo.png`,
    type: "article",
  },
  twitter: {
    card: "summary_large_image",
    title: `Surah ${surah.nameLatin} - My Qalam`,
    description,
    image: `${baseUrl}/logo.png`,
  },
  schemas
};

const hasBismillah = number !== 1 && number !== 9;
---

<Root {...pageProps}>
  <div class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
    <SurahHeader surah={surah} />
    
    {hasBismillah && (
      <div class="text-center py-8 text-3xl font-arabic text-foreground/80 mb-8" style="font-family: 'KFGQPC Uthman Taha Naskh', serif;" dir="rtl">
        بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ
      </div>
    )}
    
    <div class="flex flex-col">
      {ayahs.map((ayah) => (
        <AyahItem 
          ayahNumber={ayah.ayahNumber}
          arabicText={ayah.arabicText}
          translationId={ayah.translationId}
          tafsirContent={tafsirMap.get(ayah.id)}
          surahNumber={surah.number}
          surahName={surah.nameLatin}
        />
      ))}
    </div>
    
    <div class="mt-12 flex justify-between items-center border-t border-border/40 pt-8">
      {number > 1 ? (
        <a href={`/quran/${number - 1}`} class="text-sm font-medium hover:text-primary transition-colors">
          &larr; Surah Sebelumnya
        </a>
      ) : <div></div>}
      
      {number < 114 ? (
        <a href={`/quran/${number + 1}`} class="text-sm font-medium hover:text-primary transition-colors">
          Surah Selanjutnya &rarr;
        </a>
      ) : <div></div>}
    </div>
  </div>
</Root>
